{
  "ci": false,
  "plugins": [
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",
    [
      "@semantic-release/changelog",
      {
        "changelogFile": "HISTORY.md"
      }
    ],
    [
      "semantic-release-replace-plugin",
      {
        "replacements": [
          {
            "files": ["src/AbstractClient.php"],
            "from": "\"\\d+\\.\\d+\\.\\d+\"",
            "to": "\"${nextRelease.version}\"",
            "countMatches": true
          }
        ]
      }
    ],
    [
      "@semantic-release/exec",
      {
        "prepareCmd": "composer run-script docs && composer run-script generate-uml",
        "successCmd": "bash .github/scripts/publish-docs.sh"
      }
    ],
    [
      "@semantic-release/git",
      {
        "assets": [
          "HISTORY.md",
          "@(package|composer).json",
          "pnpm-lock.yaml",
          "src/AbstractClient.php"
        ]
      }
    ],
    "semantic-release-teams-notify-plugin",
    "@semantic-release/github"
  ]
}
