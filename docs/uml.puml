@startuml class-diagram
  class "AbstractSocketConfig\n<b>Shared base for all registrar SocketConfig implementations.</b>" as AbstractSocketConfig {
    #login : string
    #pw : string
    #oteUrl : string
    #liveUrl : string
    #socketTimeout : int
    #needsIDNConvert : bool
    #roleSeparator : string
    +setLogin(value)
    +getLogin()
    +setPassword(value)
    +getSession()
    +setSession(value)
    +setPersistent(value)
    +getPersistent()
    +getOTEUrl()
    +getLiveUrl()
    +getSocketTimeout()
    +getNeedsIDNConvert()
    +getRoleSeparator()
    {abstract} #getPOSTDataParams(command, secured)
    +getPOSTData(command, secured)
  }
  interface "LoggerInterface\n<b>Common Logger Interface</b>" as LoggerInterface {
    +log(post, r, error)
  }
  class "CommandFormatter\n<b>CommandFormatter</b>" as CommandFormatter {
    {static} +getSortedCommand(command)
    {static} +flattenCommand(cmd, toupper)
    {static} +formatCommand(command)
    {static} -getPropertiesContactFieldsWithPriority()
    {static} -getPropertiesPriority()
    {static} -findPriority(key, priority)
  }
  interface "ResponseInterface\n<b>Common Response Interface</b>" as ResponseInterface {
    +__construct(raw, cmd, ph)
    +getCode()
    +getDescription()
    +getRequestURL()
    +getPlain()
    +getQueuetime()
    +getHash()
    +getRuntime()
    +isError()
    +isSuccess()
    +isTmpError()
    +isPending()
    +addColumn(key, data)
    +addRecord(h)
    +getColumn(key)
    +getColumnIndex(colkey, index)
    +getColumnKeys()
    +getColumns()
    +getCommand()
    +getCommandPlain()
    +getContext()
    +getCurrentPageNumber()
    +getCurrentRecord()
    +getFirstRecordIndex()
    +getLastRecordIndex()
    +getListHash()
    +getNextRecord()
    +getNextPageNumber()
    +getNumberOfPages()
    +getPagination()
    +getPreviousPageNumber()
    +getPreviousRecord()
    +getRecord(idx)
    +getRecords()
    +getRecordsCount()
    +getRecordsTotalCount()
    +getRecordsLimitation()
    +hasNextPage()
    +hasPreviousPage()
    +rewindRecordList()
  }
  enum "Registrar\n<b>Supported registrar identifiers.</b>" as Registrar {
  }
  class "ClientFactory\n<b>ClientFactory</b>" as ClientFactory {
    {static} +getClient(params, logger)
  }
  interface "RecordInterface\n<b>Common Record Interface</b>" as RecordInterface {
    +__construct(data)
    +getData()
    +getDataByKey(key)
  }
  class "HttpTransport\n<b>Low-level HTTP transport over cURL.</b>" as HttpTransport {
    -handle : ?CurlHandle
    +post(url, data, timeout, userAgent, options)
    +close()
  }
  class "AbstractClient\n<b>Shared foundation for all registrar API clients.</b>" as AbstractClient {
    #context : array<string, mixed>
    #socketURL : string
    #socketConfig : AbstractSocketConfig
    #debugMode : bool
    #ua : string
    #curlopts : array<int, mixed>
    #logger : LoggerInterface
    #isOTE : bool
    #transport : HttpTransport
    +__construct()
    {abstract} +request(cmd)
    {abstract} #newSocketConfig()
    {abstract} +setDefaultLogger()
    +setCustomLogger(customLogger)
    +enableDebugMode()
    +disableDebugMode()
    +getPOSTData(cmd, secured)
    +getSession()
    +getURL()
    +setUserAgent(str, rv, modules)
    +getUserAgent()
    +setProxy(proxy)
    +getProxy()
    +setReferer(referer)
    +getReferer()
    +getVersion()
    +setURL(value)
    +setSession(value)
    +setCredentials(uid, pw)
    +setRoleCredentials(uid, role, pw)
    +useHighPerformanceConnectionSetup()
    +IDNConvert(domains)
    #autoIDNConvert(cmd)
    #executeCurl(data, cfg, extraCurlOpts)
    +close()
    +getLiveUrl()
    +isOTE()
    +useOTESystem()
    +useLIVESystem()
    +setContext(context)
  }
  interface "ColumnInterface\n<b>Common Column Interface</b>" as ColumnInterface {
    +__construct(key, data)
    +getKey()
    +getData()
    +getDataByIndex(idx)
  }
  package CNR as CNR {
    class "ResponseTranslator\n<b>CNR ResponseTranslator</b>" as CNR_ResponseTranslator {
      -descriptionRegexMap : array<string, string>
      -descriptionRawPatternMap : array<string, string>
      {static} +translate(raw, cmd, ph)
      {static} -findMatch(regex, newraw, val, cmd)
      {static} #replacePlaceholders(raw, ph)
    }
    class "ResponseTemplateManager\n<b>CNR ResponseTemplateManager</b>" as CNR_ResponseTemplateManager {
      +templates : array<string>
      {static} +generateTemplate(code, description)
      {static} +addTemplate(id, plain, descr)
      {static} +getTemplate(id)
      {static} +getTemplates()
      {static} +hasTemplate(id)
      {static} +isTemplateMatchHash(tpl, id)
      {static} +isTemplateMatchPlain(plain, id)
    }
    class "Column\n<b>CNR Column</b>" as CNR_Column {
      +length : int
      -key : string
      -data : array
      +__construct(key, data)
      +getKey()
      +getData()
      +getDataByIndex(idx)
      -hasDataIndex(idx)
    }
    class "Record\n<b>CNR Record</b>" as CNR_Record {
      -data : array<string, mixed>
      +__construct(data)
      +getData()
      +getDataByKey(key)
      -hasData(key)
    }
    class "SessionCapable\n<b>Provides session-based API communication methods.</b>" as CNR_SessionCapable {
      +login()
      +logout()
      +saveSession(session)
      +reuseSession(session)
    }
    class "SessionClient\n<b>CNR Session API Client</b>" as CNR_SessionClient {
    }
    class "SocketConfig\n<b>CNR SocketConfig</b>" as CNR_SocketConfig {
      #oteUrl : string
      #liveUrl : string
      #socketTimeout : int
      #needsIDNConvert : bool
      #roleSeparator : string
      -persistent : bool
      -session : string
      -parameters : array{login: string, password: string, command: string, session: string}
      #getPOSTDataParams(command, secured)
      +setPersistent(value)
      +getPersistent()
      +getSession()
      +setLogin(value)
      +setPassword(value)
      +setSession(value)
    }
    class "Client\n<b>CNR API Client</b>" as CNR_Client {
      #newSocketConfig()
      +setDefaultLogger()
      +request(cmd)
      +requestNextResponsePage(rr)
      +requestAllResponsePages(cmd)
    }
    class "ResponseParser\n<b>CNR ResponseParser</b>" as CNR_ResponseParser {
      {static} +parse(raw)
    }
    class "Logger\n<b>CNR Logger</b>" as CNR_Logger {
      +log(post, r, error)
    }
    class "Response\n<b>CNR Response</b>" as CNR_Response {
      #command : array<string, string>
      #raw : string
      #hash : array<string, mixed>
      #paginationkeys : non-empty-string
      #columnkeys : string[]
      #columns : ColumnInterface[]
      #recordIndex : int
      #records : Record[]
      #context : array<string, mixed>
      #requestUrl : string
      +__construct(raw, cmd, ph, context)
      +getContext()
      +getRequestURL()
      +getCode()
      +getDescription()
      +getPlain()
      +getQueuetime()
      +getHash()
      +getRuntime()
      +isError()
      +isSuccess()
      +isTmpError()
      +isPending()
      +addColumn(key, data)
      +addRecord(h)
      +getColumn(key)
      +getColumnIndex(colkey, index)
      +getColumnKeys(filterPaginationKeys)
      +getColumns()
      +getCommand()
      +getCommandPlain()
      +getCurrentPageNumber()
      +getCurrentRecord()
      +getFirstRecordIndex()
      +getLastRecordIndex()
      +getListHash()
      +getNextRecord()
      +getNextPageNumber()
      +getNumberOfPages()
      +getPagination()
      +getPreviousPageNumber()
      +getPreviousRecord()
      +getRecord(idx)
      +getRecords()
      +getRecordsCount()
      +getRecordsTotalCount()
      +getRecordsLimitation()
      +hasNextPage()
      +hasPreviousPage()
      +rewindRecordList()
      -hasColumn(key)
      -hasCurrentRecord()
      -hasNextRecord()
      -hasPreviousRecord()
      -getHashString(key, default)
    }
  }
  package MONIKER as MONIKER {
    class "SessionClient\n<b>Moniker Session API Client</b>" as MONIKER_SessionClient {
    }
    class "SocketConfig\n<b>Moniker SocketConfig — same API platform as IBS; only the endpoints differ.</b>" as MONIKER_SocketConfig {
      #oteUrl : string
      #liveUrl : string
    }
    class "Client\n<b>Moniker API Client — same platform as IBS; only the endpoints differ.</b>" as MONIKER_Client {
      #newSocketConfig()
    }
  }
  package IBS as IBS {
    class "ResponseTranslator\n<b>IBS ResponseTranslator</b>" as IBS_ResponseTranslator {
      -descriptionRegexMap : array<string, string>
      -descriptionRawPatternMap : array<string, string>
      {static} +translate(raw, cmd, ph)
      {static} -findMatch(regex, newraw, val)
      {static} #replacePlaceholders(raw, ph)
    }
    class "ResponseTemplateManager\n<b>IBS ResponseTemplateManager</b>" as IBS_ResponseTemplateManager {
      +templates : array<string>
      {static} +generateTemplate(status, description)
      {static} +addTemplate(id, plain, descr)
      {static} +getTemplate(id)
      {static} +getTemplates()
      {static} +hasTemplate(id)
      {static} +isTemplateMatchHash(tpl, id)
      {static} +isTemplateMatchPlain(plain, id)
    }
    class "Column\n<b>IBS Column</b>" as IBS_Column {
      +length : int
      -key : string
      -data : array
      +__construct(key, data)
      +getKey()
      +getData()
      +getDataByIndex(idx)
    }
    class "Record\n<b>IBS Record</b>" as IBS_Record {
    }
    class "SessionClient\n<b>IBS Session API Client</b>" as IBS_SessionClient {
    }
    class "SocketConfig\n<b>IBS SocketConfig</b>" as IBS_SocketConfig {
      #oteUrl : string
      #liveUrl : string
      #socketTimeout : int
      #needsIDNConvert : bool
      -parameters : array{login: string, password: string}
      #getPOSTDataParams(command, secured)
    }
    class "Client\n<b>IBS API Client</b>" as IBS_Client {
      #newSocketConfig()
      +setDefaultLogger()
      +getSession()
      +setSession(value)
      +setRoleCredentials(uid, role, pw)
      #autoIDNConvert(cmd)
      +request(cmd, path)
      +useHighPerformanceConnectionSetup()
    }
    class "ResponseParser\n<b>IBS ResponseParser</b>" as IBS_ResponseParser {
      {static} +parse(raw, cmd)
    }
    class "Logger\n<b>IBS Logger</b>" as IBS_Logger {
      +log(post, r, error)
    }
    class "Response\n<b>IBS Response</b>" as IBS_Response {
      #paginationkeys : non-empty-string
      #context : array<string, mixed>
      +__construct(raw, cmd, ph, context)
      +getCode()
      +getStatus()
      +getDescription()
      +getPlain()
      +getQueuetime()
      +getHash()
      +getRuntime()
      +isError()
      +isSuccess()
      +isTmpError()
      +isPending()
      +addColumn(key, data)
      +addRecord(h)
      +getColumn(key)
      +getColumnIndex(colkey, index)
      +getColumnKeys(filterPaginationKeys)
      +getColumns()
      +getCommand()
      +getCommandPlain()
      +getCurrentPageNumber()
      +getCurrentRecord()
      +getFirstRecordIndex()
      +getLastRecordIndex()
      +getListHash()
      +getNextRecord()
      +getNextPageNumber()
      +getNumberOfPages()
      +getPagination()
      +getPreviousPageNumber()
      +getPreviousRecord()
      +getRecord(idx)
      +getRecords()
      +getRecordsCount()
      +getRecordsTotalCount()
      +getRecordsLimitation()
      +hasNextPage()
      +hasPreviousPage()
      +rewindRecordList()
      -hasColumn(key)
      -hasCurrentRecord()
      -hasNextRecord()
      -hasPreviousRecord()
      -getHashString(key, default)
    }
  }
